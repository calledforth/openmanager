{
  "name": "@openmanager/convex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./_generated/api": {
      "types": "./convex/_generated/api.d.ts",
      "import": "./convex/_generated/api.js",
      "default": "./convex/_generated/api.js"
    },
    "./_generated/server": {
      "types": "./convex/_generated/server.d.ts",
      "import": "./convex/_generated/server.js",
      "default": "./convex/_generated/server.js"
    },
    "./_generated/dataModel": {
      "types": "./convex/_generated/dataModel.d.ts"
    }
  },
  "scripts": {
    "dev": "node scripts/convex-dev.mjs",
    "codegen": "convex codegen",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "format": "prettier --write \"convex/**/*.ts\"",
    "format:check": "prettier --check \"convex/**/*.ts\""
  },
  "dependencies": {
    "convex": "catalog:"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
