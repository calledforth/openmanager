{
  "name": "@openmanager/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/contracts/index.ts",
      "default": "./src/contracts/index.ts"
    },
    "./contracts/*": {
      "types": "./src/contracts/*.ts",
      "default": "./src/contracts/*.ts"
    },
    "./lib/*": {
      "types": "./src/lib/*.ts",
      "default": "./src/lib/*.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
