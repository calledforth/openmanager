{
  "name": "@openmanager/desktop",
  "version": "0.1.6-alpha.1",
  "private": true,
  "description": "Desktop GUI for managing OpenCode agent sessions",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist:win": "pnpm build && electron-builder --win --x64 --publish never",
    "preview": "electron-vite preview",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "lint": "eslint . ../../packages/shared/src",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"../../packages/shared/src/**/*.ts\" \"../mobile/src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"../../packages/shared/src/**/*.ts\" \"../mobile/src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@agentpack/contract": "workspace:*",
    "@agentpack/runtime": "workspace:*",
    "@agentpack/view": "workspace:*",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/public-sans": "^5.2.7",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@openmanager/convex": "workspace:*",
    "@openmanager/shared": "workspace:*",
    "@phosphor-icons/react": "^2.1.10",
    "@react-scan/vite-plugin-react-scan": "^0.2.3",
    "@tailwindcss/vite": "^4.2.0",
    "@tanstack/react-virtual": "^3.13.22",
    "autoprefixer": "^10.4.24",
    "clsx": "^2.1.1",
    "convex": "catalog:",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9",
    "motion": "^12.34.3",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.0.8",
    "@storybook/addon-docs": "^10.0.8",
    "@storybook/addon-links": "^10.0.8",
    "@storybook/react-vite": "^10.0.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "react-scan": "^0.5.3",
    "storybook": "^10.0.8",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vitest": "^4.0.18"
  }
}
