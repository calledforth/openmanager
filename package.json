{
  "name": "openmanager",
  "version": "0.1.5-alpha.1",
  "private": true,
  "description": "Desktop GUI for managing OpenCode agent sessions",
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "scripts": {
    "dev": "pnpm --filter @openmanager/desktop dev",
    "build": "pnpm --filter @openmanager/desktop build",
    "dist:win": "pnpm --filter @openmanager/desktop dist:win",
    "preview": "pnpm --filter @openmanager/desktop preview",
    "storybook": "pnpm --filter @openmanager/desktop storybook",
    "storybook:build": "pnpm --filter @openmanager/desktop storybook:build",
    "mobile": "pnpm --filter @openmanager/mobile start",
    "mobile:android": "pnpm --filter @openmanager/mobile exec expo run:android",
    "typecheck": "pnpm --filter @agentpack/contract typecheck && pnpm --filter @agentpack/runtime typecheck && pnpm --filter @agentpack/view typecheck && pnpm --filter @openmanager/shared typecheck && pnpm --filter @openmanager/desktop typecheck && pnpm --filter @openmanager/convex typecheck && pnpm --filter @openmanager/mobile typecheck",
    "lint": "pnpm --filter @openmanager/desktop lint",
    "format": "pnpm --filter @openmanager/desktop format && pnpm --filter @openmanager/convex format",
    "format:check": "pnpm --filter @openmanager/desktop format:check && pnpm --filter @openmanager/convex format:check",
    "test": "pnpm --filter @openmanager/desktop test",
    "test:watch": "pnpm --filter @openmanager/desktop test:watch",
    "convex:dev": "pnpm --filter @openmanager/convex dev",
    "ci": "pnpm typecheck && pnpm lint && pnpm test",
    "ci:desktop": "pnpm --filter @openmanager/desktop typecheck && pnpm --filter @openmanager/desktop lint && pnpm --filter @openmanager/desktop test",
    "release:prepare": "node scripts/prepare-release.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1"
  }
}
